# Server-side only. Never expose this value in app.js or index.html.
OPENAI_API_KEY=

# Low-latency tutor model. The deterministic tutor remains available without a key.
OPENAI_TUTOR_MODEL=gpt-5.6-luna

# Cost-sensitive structured feedback for student long answers.
OPENAI_WRITING_MODEL=gpt-5.6-luna
